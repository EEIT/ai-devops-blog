# Normalize all text files to LF in the repository.
# Prevents CRLF/LF drift when Git Bash (Windows, autocrlf=true)
# and WSL Ubuntu (autocrlf=false) access the same worktree.

# Default: auto-detect text, store as LF, check out as LF
* text=auto eol=lf

# Explicit text types (redundant with text=auto but safer)
*.md       text eol=lf
*.markdown text eol=lf
*.html     text eol=lf
*.xml      text eol=lf
*.svg      text eol=lf
*.css      text eol=lf
*.scss     text eol=lf
*.js       text eol=lf
*.ts       text eol=lf
*.json     text eol=lf
*.toml     text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.py       text eol=lf
*.sh       text eol=lf
LICENSE    text eol=lf

# Binary files — never treat as text, never normalize
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.avif binary
*.pdf  binary
*.zip  binary
*.gz   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
